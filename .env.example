# Vercel / Python API
# Supabase Supavisor transaction-pooler URL (port 6543). Keep it server-only.
# Do not commit a real connection string.
SUPABASE_DB_URL=
YACHAT_AUTH_SECRET=

# Optional Supavisor resilience tuning. Defaults are safe for Vercel's
# short-lived functions: two attempts, three seconds per connect attempt.
YACHAT_DB_CONNECT_ATTEMPTS=2
YACHAT_DB_CONNECT_TIMEOUT_SECONDS=3

# Production schema is managed by Supabase migrations. Leave false on Vercel;
# true is only for an emergency/local database bootstrap.
YACHAT_RUNTIME_SCHEMA_BOOTSTRAP=false

# Optional: limit public users returned to the app.
YACHAT_PUBLIC_USER_LIMIT=100

# Optional: set to true only if contacts are intentionally public.
YACHAT_PUBLIC_CONTACTS=false

# Optional: return verification codes directly to the web app.
# Keep false outside isolated tests.
YACHAT_RETURN_DEV_CODE=false

# Telegram confirmation bot. Store real values only in local/Vercel env.
YACHAT_TELEGRAM_BOT_TOKEN=
YACHAT_TELEGRAM_WEBHOOK_SECRET=

# Web Push notifications. Generate VAPID keys and set them in Vercel env.
YACHAT_VAPID_PUBLIC_KEY=
YACHAT_VAPID_PRIVATE_KEY=
YACHAT_VAPID_SUBJECT=mailto:admin@example.com

# Optional: comma-separated origins for additional trusted web clients.
# The YaChat and Digital Bar production origins are included by default.
YACHAT_CORS_ORIGINS=

# Optional: force HTTPS on Vercel/proxy requests. Keep true for production.
YACHAT_FORCE_HTTPS=true
