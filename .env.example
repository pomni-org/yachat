# Vercel / Python API
# Use a hosted Postgres database URL. Do not commit real secrets.
YACHAT_USERS_DB_URL=
# Also accepted from Vercel/Neon/Supabase integrations:
# DATABASE_URL, POSTGRES_URL, POSTGRES_PRISMA_URL, POSTGRES_URL_NON_POOLING,
# NEON_DATABASE_URL, SUPABASE_DB_URL
YACHAT_AUTH_SECRET=

# Optional: limit public users returned to the app.
YACHAT_PUBLIC_USER_LIMIT=100

# Optional: set to true only if contacts are intentionally public.
YACHAT_PUBLIC_CONTACTS=false

# Optional: return verification codes directly to the web app.
# Keep true for test builds without an SMS provider.
YACHAT_RETURN_DEV_CODE=true

# Web Push notifications. Generate VAPID keys and set them in Vercel env.
YACHAT_VAPID_PUBLIC_KEY=
YACHAT_VAPID_PRIVATE_KEY=
YACHAT_VAPID_SUBJECT=mailto:admin@example.com
